{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "notable-plugin-api": ["../frontend/src/plugin-api/index.ts"],
      "@codemirror/*": ["../frontend/node_modules/@codemirror/*"],
      "@lezer/*": ["../frontend/node_modules/@lezer/*"],
      "yjs": ["../frontend/node_modules/yjs"]
    }
  },
  "include": ["*/src/**/*.ts"]
}
